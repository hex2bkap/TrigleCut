<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PicOrient.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PicOrient"
    Title="PicOrient">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <MenuBar Grid.Row="0">
            <MenuBarItem Title="ヘルプ">
                <MenuFlyoutItem Text="ログフォルダを開く" Click="OpenLogFolder_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="バージョン情報" Click="AboutMenuItem_Click"/>
            </MenuBarItem>
        </MenuBar>

        <!-- メインコンテンツ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="20,16,20,24" Spacing="16">

                <!-- ① フォルダ選択 -->
                <TextBlock Text="フォルダ選択" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                <Border
                    x:Name="DropAreaBorder"
                    BorderThickness="2"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    MinHeight="96"
                    AllowDrop="True"
                    DragOver="DropArea_DragOver"
                    DragEnter="DropArea_DragEnter"
                    DragLeave="DropArea_DragLeave"
                    Drop="DropArea_Drop"
                    Padding="16">
                    <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8B7;" FontSize="24"/>
                            <TextBlock Text="フォルダをここにドロップ" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock
                            Text="または"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Button
                            Content="フォルダを選択..."
                            HorizontalAlignment="Center"
                            Command="{x:Bind ViewModel.SelectSourceFolderCommand}"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.SourceFolder, Mode=OneWay}"
                            TextWrapping="Wrap"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            MaxWidth="600"/>
                    </StackPanel>
                </Border>

                <!-- 出力先 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="出力先" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <RadioButton
                        Content="ソースフォルダ内に作成（推奨）"
                        IsChecked="{x:Bind ViewModel.UseSourceFolderAsOutput, Mode=TwoWay}"/>
                    <RadioButton
                        Content="別のフォルダを指定"
                        IsChecked="{x:Bind ViewModel.UseCustomOutputFolder, Mode=TwoWay}"/>
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.CustomOutputRowVisibility, Mode=OneWay}">
                        <TextBox
                            Width="420"
                            Text="{x:Bind ViewModel.CustomOutputFolder, Mode=TwoWay}"
                            PlaceholderText="出力フォルダのパス"
                            IsReadOnly="True"/>
                        <Button
                            Content="参照..."
                            Command="{x:Bind ViewModel.SelectOutputFolderCommand}"/>
                    </StackPanel>
                </StackPanel>

                <Border BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,0"/>

                <!-- ② 設定 -->
                <TextBlock Text="設定" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                <Grid ColumnSpacing="32" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 操作 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="操作" VerticalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16">
                        <RadioButton Content="コピー" IsChecked="{x:Bind ViewModel.IsCopy, Mode=TwoWay}"/>
                        <RadioButton Content="移動" IsChecked="{x:Bind ViewModel.IsMove, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- 重複ファイル -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="重複ファイル" VerticalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16">
                        <RadioButton Content="スキップ" IsChecked="{x:Bind ViewModel.DuplicateSkip, Mode=TwoWay}"/>
                        <RadioButton Content="上書き" IsChecked="{x:Bind ViewModel.DuplicateOverwrite, Mode=TwoWay}"/>
                        <RadioButton Content="自動リネーム" IsChecked="{x:Bind ViewModel.DuplicateRename, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- 判定閾値 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="判定閾値" VerticalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <NumberBox
                            Value="{x:Bind ViewModel.AspectRatioThreshold, Mode=TwoWay}"
                            Minimum="1.01"
                            Maximum="5.0"
                            SmallChange="0.05"
                            SpinButtonPlacementMode="Compact"
                            Width="120"/>
                        <TextBlock
                            Text="この値未満の縦横比を「中間」とみなします"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- サブフォルダ -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="サブフォルダ" VerticalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <CheckBox
                        Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                        Content="サブフォルダも処理する"
                        IsChecked="{x:Bind ViewModel.ProcessSubfolders, Mode=TwoWay}"/>

                    <!-- フォルダ名 -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="フォルダ名" VerticalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="縦" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.PortraitFolderName, Mode=TwoWay}" Width="100"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="横" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.LandscapeFolderName, Mode=TwoWay}" Width="100"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="中間" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.SquareFolderName, Mode=TwoWay}" Width="100"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,0"/>

                <!-- ③ スキャン結果 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="スキャン結果"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        VerticalAlignment="Center"/>
                    <Grid Grid.Column="1">
                        <Button
                            Content="スキャン実行"
                            Command="{x:Bind ViewModel.ScanCommand}"
                            Style="{ThemeResource AccentButtonStyle}"
                            Visibility="{x:Bind ViewModel.ScanButtonVisibility, Mode=OneWay}"/>
                        <Button
                            Content="キャンセル"
                            Command="{x:Bind ViewModel.CancelCommand}"
                            BorderThickness="1.5"
                            Visibility="{x:Bind ViewModel.ScanCancelVisibility, Mode=OneWay}">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonForeground" Color="#FF6B6B"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="#C42B1C"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#22C42B1C"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FF6B6B"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#C42B1C"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#44C42B1C"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FF8080"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#E03020"/>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 縦 -->
                    <Border Grid.Column="0" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="12">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="縦" HorizontalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.PortraitCount, Mode=OneWay}" HorizontalAlignment="Center" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="枚" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- 横 -->
                    <Border Grid.Column="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="12">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="横" HorizontalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.LandscapeCount, Mode=OneWay}" HorizontalAlignment="Center" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="枚" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- 中間 -->
                    <Border Grid.Column="2" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="12">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="中間" HorizontalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.SquareCount, Mode=OneWay}" HorizontalAlignment="Center" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="枚" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- 合計 -->
                    <Border Grid.Column="3" CornerRadius="8" Background="{ThemeResource SubtleFillColorTransparentBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="12">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="合計" HorizontalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}" HorizontalAlignment="Center" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="枚" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,0"/>

                <!-- ④ 実行 -->
                <Grid>
                    <Button
                        Content="振り分け実行"
                        HorizontalAlignment="Stretch"
                        Style="{ThemeResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.SortCommand}"
                        Visibility="{x:Bind ViewModel.SortButtonVisibility, Mode=OneWay}"/>
                    <Button
                        Content="キャンセル"
                        HorizontalAlignment="Stretch"
                        BorderThickness="1.5"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Visibility="{x:Bind ViewModel.SortCancelVisibility, Mode=OneWay}">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonForeground" Color="#FF6B6B"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#C42B1C"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#22C42B1C"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FF6B6B"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#C42B1C"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#44C42B1C"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FF8080"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#E03020"/>
                        </Button.Resources>
                    </Button>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- 固定ステータスパネル -->
        <Border
            Grid.Row="2"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel Padding="20,8,20,12" Spacing="6">

                <!-- エラー通知 InfoBar -->
                <InfoBar
                    x:Name="SortErrorInfoBar"
                    IsOpen="{x:Bind ViewModel.ShowSortErrors, Mode=OneWay}"
                    Severity="Error"
                    Title="{x:Bind ViewModel.SortErrorsTitle, Mode=OneWay}"
                    IsClosable="True"
                    Closed="SortErrorInfoBar_Closed">
                    <InfoBar.Content>
                        <StackPanel Spacing="6">
                            <TextBlock
                                Text="{x:Bind ViewModel.SortErrorsText, Mode=OneWay}"
                                IsTextSelectionEnabled="True"
                                TextWrapping="Wrap"
                                FontFamily="Consolas"
                                FontSize="12"/>
                            <HyperlinkButton
                                Content="ログフォルダを開く"
                                Click="OpenLogFolder_Click"
                                Padding="0"/>
                        </StackPanel>
                    </InfoBar.Content>
                </InfoBar>

                <ProgressBar
                    Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                    Maximum="100"
                    Visibility="{x:Bind ViewModel.ShowProgressVisibility, Mode=OneWay}"/>
                <TextBlock
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
